# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/wedding?sslmode=require

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://nathanandlauren.com

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Allowed admin emails (comma-separated)
ADMIN_EMAILS=nathan@example.com,lauren@example.com

# Public site URL (used for guest link generation)
NEXT_PUBLIC_SITE_URL=https://nathanandlauren.com

# Cloudflare R2 (for video uploads)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=wedding
R2_PUBLIC_URL=https://your-bucket.r2.dev
